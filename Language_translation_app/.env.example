# Copy this file to .env and fill in your values
# Optional: Use Google Cloud Translation API key (if you want official Google API)
# Leave empty to use the free deep-translator library (no API key needed)
GOOGLE_API_KEY=

# Flask configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# Server settings
HOST=127.0.0.1
PORT=5000
